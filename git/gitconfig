[user]
	name = Jonas Lewe
	# Email is set per-machine in ~/.gitconfig.local
	# Run install.sh or copy git/gitconfig.local.example to ~/.gitconfig.local

[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[alias]
	st = status
	co = checkout
	br = branch

[color]
	ui = auto
